rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure rule block for calendars collections
    match /calendars/{calendarId} {
      allow read: if true;
      allow create, update: if (
        request.resource.data.calendarTitle is string &&
        request.resource.data.calendarTitle.size() <= 500 &&
        request.resource.data.timeClockUrl is string &&
        request.resource.data.timeClockUrl.size() <= 1000 &&
        request.resource.data.handbookUrl is string &&
        request.resource.data.handbookUrl.size() <= 1000
      );
      allow delete: if false;
    }
  }
}
